---
import Base from '../layouts/Base.astro';
import Mascot from '../components/Mascot.astro';
import Icon from '../components/Icon.astro';
import { studio, leaveSmart } from '../data/studio';
import { organizationLd, webSiteLd } from '../data/jsonld';
---

<Base
  title="Yellow Leaves Studio — cozy indie games & apps"
  description={studio.description}
  ogImage="/og/default.png"
  jsonLd={[organizationLd, webSiteLd]}
>
  <section class="hero">
    <div class="wrap hero-grid">
      <div class="hero-copy">
        <span class="pill">✦ a cozy little indie studio</span>
        <h1>cute games &amp; apps,<br />made with care.</h1>
        <p>
          we’re a tiny studio making little games and apps (with lots of naps in between).
          <a class="link-gold" href="/leave-smart/">Leave Smart</a> is out now — our first game is
          busy snoozing.
        </p>
        <div class="hero-actions">
          <a class="btn btn--yellow" href={leaveSmart.appStoreUrl} rel="noopener">get Leave Smart</a>
          <a class="btn btn--soft" href="/about/">meet the studio</a>
        </div>
      </div>
      <div class="hero-mascot">
        <Mascot variant="full" wobble width={300} />
      </div>
    </div>
  </section>

  <section class="shelf wrap" aria-labelledby="shelf-title">
    <h2 id="shelf-title" class="shelf-title">the shelf</h2>
    <ul class="shelf-grid">
      <li class="sticker shelf-card" style="--tilt:-2deg">
        <span class="shelf-icon"><Icon name="pin" /></span>
        <h3>Leave Smart</h3>
        <p>location reminders · out now · iOS</p>
        <a class="link-gold" href="/leave-smart/" aria-label="Leave Smart on the App Store">App Store →</a>
      </li>
      <li id="the-game" class="sticker shelf-card" style="--tilt:1.6deg">
        <span class="shelf-icon"><Icon name="controller" /></span>
        <h3>our first game</h3>
        <p>still napping · follow along</p>
        <a class="link-gold" href={studio.socials[0].href} rel="noopener">peek →</a>
      </li>
      <li class="sticker shelf-card" style="--tilt:-1.2deg">
        <span class="shelf-icon"><Icon name="heart" /></span>
        <h3>say hello</h3>
        <p>we’re friendly &amp; sleepy</p>
        <a class="link-gold" href={`mailto:${studio.email}`}>email us →</a>
      </li>
    </ul>
  </section>

  <section class="wrap cozy-strip" aria-labelledby="cozy-title">
    <div class="cozy-mascot"><Mascot variant="full" width={120} /></div>
    <div class="cozy-copy">
      <h2 id="cozy-title">made slowly, with care.</h2>
      <p>a tiny studio · small on purpose · private by default · since {studio.foundingYear}</p>
    </div>
    <a class="btn btn--yellow cozy-btn" href="/about/">about us</a>
  </section>
</Base>

<style>
  .hero {
    background: radial-gradient(circle at 72% 38%, #ffe89e, var(--cream) 70%);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    align-items: center;
    gap: 2rem;
    padding-block: clamp(2.5rem, 6vh, 4.5rem);
  }

  .hero h1 {
    font-size: var(--text-hero);
    margin: 1rem 0 0.8rem;
  }

  .hero-copy p {
    color: var(--ink-soft);
    font-size: 1.08rem;
    max-width: 34ch;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1.6rem;
  }

  .hero-mascot {
    display: flex;
    justify-content: center;
  }

  .shelf {
    padding-block: var(--space-section);
  }

  .shelf-title {
    font-size: var(--text-title);
    margin-bottom: 1.6rem;
  }

  .shelf-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.4rem;
  }

  .shelf-card {
    padding: 1.4rem;
    transform: rotate(var(--tilt));
    transition: transform 0.18s ease;
  }

  .shelf-card:hover {
    transform: rotate(0) translateY(-4px);
  }

  .shelf-icon {
    display: inline-flex;
    width: 46px;
    height: 46px;
    border-radius: var(--radius-sm);
    background: #ffe89e;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.6rem;
  }

  .shelf-card h3 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.15rem;
  }

  .shelf-card p {
    font-size: 0.9rem;
    color: var(--ink-soft);
    margin: 0.2rem 0 0.6rem;
  }

  .cozy-strip {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    background: var(--strip);
    border: 2px solid var(--strip-border);
    border-radius: var(--radius);
    padding: 1.2rem 1.5rem;
    margin-bottom: var(--space-section);
    flex-wrap: wrap;
  }

  .cozy-copy {
    flex: 1;
    min-width: 12rem;
  }

  .cozy-copy h2 {
    font-size: 1.4rem;
  }

  .cozy-copy p {
    color: var(--ink-soft);
    font-size: 0.95rem;
    margin-top: 0.2rem;
  }

  @media (max-width: 820px) {
    .hero-grid {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .hero-copy p {
      margin-inline: auto;
    }
    .hero-actions {
      justify-content: center;
    }
    .hero-mascot {
      order: -1;
    }
    .shelf-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
