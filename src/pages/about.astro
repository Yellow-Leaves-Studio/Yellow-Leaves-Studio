---
import Base from '../layouts/Base.astro';
import Mascot from '../components/Mascot.astro';
import Icon from '../components/Icon.astro';
import { studio } from '../data/studio';
import { organizationLd, breadcrumbLd } from '../data/jsonld';

const values = [
  { icon: 'leaf', title: 'small on purpose', body: 'one thing, done well — then shipped. no sprawl, no “suite.”', tilt: '-2.5deg' },
  { icon: 'lock', title: 'private by default', body: 'your life isn’t our business model. Leave Smart collects nothing.', tilt: '2deg' },
  { icon: 'moon', title: 'finished, then enjoyed', body: 'we’d rather ship something complete than run a forever-beta.', tilt: '-1.5deg' },
] as const;

const crumbs = breadcrumbLd([
  { name: 'Home', path: '/' },
  { name: 'About', path: '/about/' },
]);
---

<Base
  title="About Yellow Leaves Studio"
  description="Why Yellow Leaves? The story of a tiny independent studio making games and apps that are small on purpose, private by default, and shipped finished."
  ogImage="/og/about.png"
  jsonLd={[organizationLd, crumbs]}
  activeNav="about"
>
  <section class="ab-hero">
    <div class="wrap ab-hero-grid">
      <div>
        <span class="pill">✦ about the studio</span>
        <h1>a tiny studio<br />with a cozy name.</h1>
        <p>
          leaves turn yellow when a tree decides what matters — it lets the old season go and saves
          its strength for what grows next. we liked that enough to name a studio after it.
        </p>
        <p>
          Yellow Leaves Studio is a one-person studio started in {studio.foundingYear} by {studio.founder}.
          we make little games and apps slowly, and finish them properly.
          <a class="link-gold" href="/leave-smart/">Leave Smart</a> is on the App Store — our first
          game is busy napping (so is the panda).
        </p>
      </div>
      <div class="ab-mascot"><Mascot variant="full" wobble width={240} /></div>
    </div>
  </section>

  <section class="wrap ab-values" aria-labelledby="values-title">
    <h2 id="values-title">three things we hold onto</h2>
    <ul class="ab-values-grid">
      {
        values.map((v) => (
          <li class="sticker ab-value" style={`--tilt:${v.tilt}`}>
            <span class="ab-value-icon"><Icon name={v.icon} size={26} /></span>
            <h3>{v.title}</h3>
            <p>{v.body}</p>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="wrap ab-hello" aria-labelledby="hello-title">
    <Mascot variant="full" width={120} />
    <div class="ab-hello-copy">
      <h2 id="hello-title">say hello</h2>
      <p>we read everything. tell us what you’re building, or just come say hi.</p>
      <div class="ab-hello-actions">
        <a class="btn btn--yellow" href={`mailto:${studio.email}`}>email us</a>
        {studio.socials.map((s) => <a class="btn btn--soft" href={s.href} rel="noopener">{s.label}</a>)}
      </div>
    </div>
  </section>
</Base>

<style>
  .ab-hero {
    background: radial-gradient(circle at 80% 40%, #ffe89e, var(--cream) 72%);
  }

  .ab-hero-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    align-items: center;
    gap: 2rem;
    padding-block: clamp(2.5rem, 6vh, 4.5rem);
  }

  .ab-hero h1 {
    font-size: var(--text-title);
    margin: 0.9rem 0 0.9rem;
  }

  .ab-hero p {
    color: var(--ink-soft);
    max-width: 46ch;
    margin-bottom: 0.8rem;
  }

  .ab-mascot {
    display: flex;
    justify-content: center;
  }

  .ab-values {
    padding-block: var(--space-section);
  }

  .ab-values > h2 {
    font-size: var(--text-title);
    text-align: center;
    margin-bottom: 2rem;
  }

  .ab-values-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.4rem;
  }

  .ab-value {
    padding: 1.5rem;
    transform: rotate(var(--tilt));
    transition: transform 0.18s ease;
  }

  .ab-value:hover {
    transform: rotate(0) translateY(-4px);
  }

  .ab-value-icon {
    display: inline-flex;
    width: 46px;
    height: 46px;
    border-radius: var(--radius-sm);
    background: #ffe89e;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.6rem;
  }

  .ab-value h3 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.15rem;
  }

  .ab-value p {
    font-size: 0.92rem;
    color: var(--ink-soft);
    margin-top: 0.25rem;
  }

  .ab-hello {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.6rem;
    flex-wrap: wrap;
    background: var(--strip);
    border: 2px solid var(--strip-border);
    border-radius: var(--radius);
    padding: 1.6rem;
    margin-bottom: var(--space-section);
  }

  .ab-hello-copy {
    max-width: 24rem;
  }

  .ab-hello-copy h2 {
    font-size: 1.5rem;
  }

  .ab-hello-copy p {
    color: var(--ink-soft);
    margin: 0.4rem 0 1rem;
  }

  .ab-hello-actions {
    display: flex;
    gap: 0.7rem;
    flex-wrap: wrap;
  }

  @media (max-width: 820px) {
    .ab-hero-grid {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .ab-hero p {
      margin-inline: auto;
    }
    .ab-mascot {
      order: -1;
    }
    .ab-values-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
