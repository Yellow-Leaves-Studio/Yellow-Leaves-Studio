---
import Base from '../layouts/Base.astro';
import Mascot from '../components/Mascot.astro';
---

<Base
  title="Page not found — Yellow Leaves Studio"
  description="This page wandered off. Head back to Yellow Leaves Studio."
>
  <section class="nf wrap">
    <div class="nf-mascot">
      <Mascot variant="full" sleepy width={200} title="The panda, napping" />
      <span class="z z1">z</span>
      <span class="z z2">z</span>
      <span class="z z3">z</span>
    </div>
    <p class="nf-code">404</p>
    <h1>this page is taking a nap.</h1>
    <p class="nf-text">
      the page you’re after isn’t here — maybe it wandered off, maybe it never woke up. let’s get
      you back somewhere cozy.
    </p>
    <a class="btn btn--yellow" href="/">back home</a>
  </section>
</Base>

<style>
  .nf {
    text-align: center;
    padding-block: clamp(2.5rem, 8vh, 5rem);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .nf-mascot {
    position: relative;
    display: inline-block;
  }

  .z {
    position: absolute;
    font-family: var(--font-display);
    font-weight: 800;
    color: #cdbf94;
  }

  .z1 {
    top: 14%;
    right: -2%;
    font-size: 1.3rem;
  }

  .z2 {
    top: 2%;
    right: 12%;
    font-size: 0.95rem;
    color: #dccfa6;
  }

  .z3 {
    top: 24%;
    right: -12%;
    font-size: 1.7rem;
    color: #bdae82;
  }

  .nf-code {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(3rem, 9vw, 4.5rem);
    line-height: 1;
    color: var(--yellow);
    -webkit-text-stroke: 3px var(--ink);
    margin-top: 0.4rem;
  }

  .nf h1 {
    font-size: var(--text-title);
    margin-top: 0.6rem;
  }

  .nf-text {
    color: var(--ink-soft);
    max-width: 40ch;
    margin: 0.6rem auto 1.4rem;
  }
</style>
