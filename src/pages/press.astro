---
import Base from '../layouts/Base.astro';
import Mascot from '../components/Mascot.astro';
import Icon from '../components/Icon.astro';
import { studio, leaveSmart } from '../data/studio';
import { organizationLd, breadcrumbLd } from '../data/jsonld';

const facts: [string, string][] = [
  ['studio', studio.name],
  ['founded', studio.foundingYear],
  ['founder', studio.founder],
  ['focus', 'indie games & apps'],
  ['released', `${leaveSmart.name} (iOS, free)`],
  ['in development', 'unannounced game'],
  ['contact', studio.email],
];

const crumbs = breadcrumbLd([
  { name: 'Home', path: '/' },
  { name: 'Press', path: '/press/' },
]);
---

<Base
  title="Press kit — Yellow Leaves Studio"
  description="Press kit for Yellow Leaves Studio: fact sheet, boilerplate, logo and mascot downloads, and press contact."
  ogImage="/og/press.png"
  jsonLd={[organizationLd, crumbs]}
>
  <section class="wrap pr-hero">
    <Mascot variant="full" width={130} />
    <div class="pr-hero-copy">
      <span class="pill">✦ press kit</span>
      <h1>everything you need to write about us.</h1>
      <p>facts, boilerplate, and panda stickers — all in one place.</p>
    </div>
  </section>

  <div class="wrap pr-grid">
    <section class="sticker pr-card" style="--tilt:-1.5deg" aria-labelledby="facts-title">
      <h2 id="facts-title">fact sheet</h2>
      <dl class="pr-facts">
        {
          facts.map(([k, v]) => (
            <div class="pr-fact">
              <dt>{k}</dt>
              <dd>{v}</dd>
            </div>
          ))
        }
      </dl>
    </section>

    <section class="sticker pr-card" style="--tilt:2deg" aria-labelledby="dl-title">
      <h2 id="dl-title">downloads</h2>
      <p class="pr-card-note">mascot &amp; logo in SVG and PNG — free to use in coverage.</p>
      <div class="pr-assets">
        <a class="pr-asset" href="/press/yellow-leaves-studio-press-kit/mascot.svg">
          <Mascot variant="full" width={84} />
          <span>mascot · SVG / PNG</span>
        </a>
        <a class="pr-asset" href="/press/yellow-leaves-studio-press-kit/mark.svg">
          <Mascot variant="face" width={58} />
          <span>face · SVG / PNG</span>
        </a>
      </div>
    </section>
  </div>

  <section class="wrap pr-boiler" aria-labelledby="boiler-title">
    <h2 id="boiler-title">boilerplate</h2>
    <p>
      Yellow Leaves Studio is a small independent studio founded in {studio.foundingYear}, making
      games and apps that are small on purpose, private by default, and shipped finished. Its first
      app, Leave Smart, brings location-based reminders to iPhone with no accounts and no data
      collection. The studio’s first game is currently in development.
    </p>
  </section>

  <section class="wrap pr-cta">
    <Mascot variant="full" width={130} />
    <div class="pr-cta-copy">
      <h2>take the whole kit with you.</h2>
      <a class="btn btn--yellow" href="/press/yellow-leaves-studio-press-kit.zip" download>
        <Icon name="download" size={18} /> download press kit (.zip)
      </a>
    </div>
  </section>
</Base>

<style>
  .pr-hero {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.4rem;
    flex-wrap: wrap;
    padding-block: clamp(2rem, 5vh, 3.5rem) 1rem;
    text-align: left;
  }

  .pr-hero-copy {
    max-width: 24rem;
  }

  .pr-hero h1 {
    font-size: var(--text-title);
    margin: 0.6rem 0 0.4rem;
  }

  .pr-hero-copy p {
    color: var(--ink-soft);
  }

  .pr-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 1.6rem;
    margin-top: 1rem;
  }

  .pr-card {
    padding: 1.5rem;
    transform: rotate(var(--tilt));
  }

  .pr-card h2 {
    font-size: 1.25rem;
    margin-bottom: 0.8rem;
  }

  .pr-facts {
    display: grid;
  }

  .pr-fact {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.55rem 0;
    border-bottom: 1px solid #f0e6cf;
    font-size: 0.92rem;
  }

  .pr-fact:last-child {
    border-bottom: none;
  }

  .pr-fact dt {
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--gold-accent);
  }

  .pr-fact dd {
    color: var(--ink);
    text-align: right;
  }

  .pr-card-note {
    color: var(--ink-soft);
    font-size: 0.9rem;
    margin-bottom: 0.9rem;
  }

  .pr-assets {
    display: flex;
    gap: 0.8rem;
  }

  .pr-asset {
    flex: 1;
    background: #ffe89e;
    border: 2px solid #f0d98a;
    border-radius: var(--radius-sm);
    padding: 0.6rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    text-decoration: none;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.72rem;
    color: #7a6f3a;
    transition: transform 0.15s ease;
  }

  .pr-asset:hover {
    transform: translateY(-3px);
  }

  .pr-boiler {
    background: var(--strip);
    border: 2px solid var(--strip-border);
    border-left: 8px solid var(--yellow);
    border-radius: var(--radius);
    padding: 1.4rem 1.6rem;
    margin-top: 1.6rem;
  }

  .pr-boiler h2 {
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
  }

  .pr-boiler p {
    color: var(--ink-soft);
    max-width: none;
  }

  .pr-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.6rem;
    flex-wrap: wrap;
    padding-block: var(--space-section);
  }

  .pr-cta-copy h2 {
    font-size: var(--text-title);
    margin-bottom: 1rem;
  }

  @media (max-width: 820px) {
    .pr-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
