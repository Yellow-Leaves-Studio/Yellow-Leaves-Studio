---
import { studio } from '../data/studio';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="wrap footer-top">
    <a class="footer-brand" href="/">Yellow Leaves Studio</a>
    <nav class="footer-nav" aria-label="Footer">
      <a href="/leave-smart/">Leave Smart</a>
      <a href="/about/">About</a>
      <a href="/press/">Press</a>
      {studio.socials.map((s) => <a href={s.href} rel="me noopener">{s.label}</a>)}
      <a href={`mailto:${studio.email}`}>Email</a>
    </nav>
  </div>
  <div class="wrap footer-fine">
    <span>© {year} Yellow Leaves Studio</span>
    <span>made with care &amp; naps</span>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: auto;
    border-top: 2px dashed var(--dashed);
    background: var(--cream);
    padding-block: 1.2rem;
  }

  .footer-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.6rem 1.2rem;
  }

  .footer-brand {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1rem;
    color: var(--ink);
    text-decoration: none;
  }

  .footer-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.1rem;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-small);
  }

  .footer-nav a {
    color: #9a8b54;
    text-decoration: none;
  }

  .footer-nav a:hover {
    color: var(--gold-accent);
    text-decoration: underline;
    text-decoration-thickness: 2px;
    text-underline-offset: 3px;
  }

  .footer-fine {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.3rem 1rem;
    margin-top: 0.8rem;
    font-size: 0.8rem;
    color: #b0a373;
  }
</style>
