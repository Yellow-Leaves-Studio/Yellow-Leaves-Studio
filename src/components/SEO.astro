---
import { studio } from '../data/studio';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  jsonLd?: object[];
  noindex?: boolean;
}

const { title, description, ogImage = '/og/default.png', jsonLd = [], noindex = false } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogUrl = new URL(ogImage, Astro.site);
---

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
<link rel="sitemap" href="/sitemap-index.xml" />
{
  noindex ? (
    <meta name="robots" content="noindex, nofollow" />
  ) : (
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
  )
}
<meta property="og:type" content="website" />
<meta property="og:site_name" content={studio.name} />
<meta property="og:locale" content="en_US" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={`${studio.name} — ${title}`} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogUrl} />
{jsonLd.map((block) => <script type="application/ld+json" set:html={JSON.stringify(block)} is:inline />)}
